SECRET_KEY=change-me-in-prod

# Encryption key for stored API keys / signing secrets. Leave blank —
# the backend auto-generates one on first boot and persists it to the
# vfusion_secrets docker volume. Set this explicitly only if you're
# managing the key out-of-band (e.g. 1Password CLI, AWS Secrets
# Manager, etc.). Format: output of Fernet.generate_key().
FERNET_KEY=

CORS_ORIGINS=http://localhost:15173
VITE_API_BASE=http://localhost:18080

# Optional. Only needed for production deploys that accept webhooks from
# Verkada's cloud via Cloudflare Tunnel. Get from Cloudflare Zero Trust
# dashboard → Networks → Tunnels → create tunnel → copy token.
# See README "Production deploy with Cloudflare Tunnel".
CF_TUNNEL_TOKEN=

# Optional. The public URL the Webhook Inbox banner displays (so users
# know what to paste into Verkada Command). Set this for named-tunnel
# deploys; in quick-tunnel mode the URL is auto-discovered.
PUBLIC_WEBHOOK_BASE=
