{
  "id": "weather-sentry",
  "name": "Weather sentry",
  "description": "Pulls real atmospheric data from OpenWeatherMap on a schedule and posts it to a Verkada Helix \"Weather\" event so ops can see live conditions next to a camera in Command and alert on hazards like wind, low visibility, or freezing temps. Enter a zip code (or lat/lon for a specific yard / job site) before enabling. Requires an OpenWeatherMap connection — free tier is fine.",
  "summary": "Schedule every 30 min -> OpenWeatherMap (real API) -> Helix weather event",
  "default_name": "Weather sentry",
  "flow": {
    "trigger_type": "schedule",
    "trigger_config": {
      "kind": "interval",
      "every_minutes": 30
    },
    "helix_event_types": [
      {
        "event_type_uid": "tpl:weather",
        "name": "☁️ Weather",
        "event_schema": {
          "conditions": "string",
          "temp": "float",
          "feelslike": "float",
          "humidity": "integer",
          "pressure": "integer",
          "windspeed": "float",
          "winddir": "integer",
          "visibility": "integer"
        }
      }
    ],
    "nodes": [
      {
        "id": "fetch_weather",
        "name": "fetch_weather",
        "label": "Fetch conditions",
        "kind": "action",
        "action_type": "weather_fetch",
        "config": {
          "connection_id": null,
          "zip": "",
          "country": "US",
          "latitude": "",
          "longitude": "",
          "units": "imperial"
        },
        "position": {
          "x": 220,
          "y": 0
        }
      },
      {
        "id": "post_helix",
        "name": "post_helix",
        "label": "Log to Helix",
        "kind": "action",
        "action_type": "verkada_helix_event",
        "config": {
          "connection_id": null,
          "camera_id": "",
          "event_type_uid": "tpl:weather",
          "attributes": {
            "conditions": "{{ steps.fetch_weather.output.json.conditions }}",
            "temp": "{{ steps.fetch_weather.output.json.temp }}",
            "feelslike": "{{ steps.fetch_weather.output.json.feels_like }}",
            "humidity": "{{ steps.fetch_weather.output.json.humidity }}",
            "pressure": "{{ steps.fetch_weather.output.json.pressure }}",
            "windspeed": "{{ steps.fetch_weather.output.json.wind_speed }}",
            "winddir": "{{ steps.fetch_weather.output.json.wind_direction }}",
            "visibility": "{{ steps.fetch_weather.output.json.visibility }}"
          },
          "time_ms": "{{ trigger.fired_at }}000"
        },
        "position": {
          "x": 220,
          "y": 240
        }
      }
    ],
    "edges": [
      {
        "id": "e_fetch_post",
        "source": "fetch_weather",
        "target": "post_helix"
      }
    ]
  },
  "tags": [
    "Cameras"
  ]
}
